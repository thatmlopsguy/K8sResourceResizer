# Load secrets from .secrets if present
source_env_if_exists .secrets

# Kind cluster name
export CLUSTER_NAME="${CLUSTER_NAME:-k8s-limits-cluster-test}"
export RUN_LOCAL="${RUN_LOCAL:-false}"

# Environment variables for K8sResourceResizer
export PROMETHEUS_PROVIDER=prometheus
export PROMETHEUS_URL=http://localhost:9090
export HISTORY_WINDOW=1h
export BUSINESS_HOURS_START=9
export BUSINESS_HOURS_END=17
export BUSINESS_DAYS="0,1,2,3,4"

# AWS
export AWS_REGION=us-east-1

# Azure

# GCP
